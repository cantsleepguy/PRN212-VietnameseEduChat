@page
@model ErrorModel
@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<section class="message-state app-card" role="alert">
    <div class="message-state__icon">
        <partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("warning", null, "app-icon--lg"))' />
    </div>
    <div class="page-eyebrow">Không thể hoàn tất yêu cầu</div>
    <h1 class="page-title">Đã xảy ra lỗi</h1>
    <p class="page-description">Hệ thống gặp sự cố khi xử lý yêu cầu của bạn. Hãy thử lại hoặc quay về trang tổng quan.</p>
    @if (Model.ShowRequestId)
    {
        <p class="request-id"><strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code></p>
    }
    <a class="btn btn-primary" asp-page="/Dashboard">Về trang tổng quan</a>
</section>
