@page
@model PRN212_VietnameseEduChat.Pages.Admin.DashboardModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard quản trị";
    Layout = "_Layout";

    var revenueByDayJson = JsonSerializer.Serialize(
        Model.Stats.RevenueByDay.Select(x => new { day = x.Day.ToString("dd/MM"), revenue = x.Revenue }));
    var revenueByPackageJson = JsonSerializer.Serialize(
        Model.Stats.RevenueByPackage.Select(x => new { name = x.PackageName, revenue = x.Revenue }));
    var packageDistributionJson = JsonSerializer.Serialize(
        Model.Stats.PackageDistribution.Select(x => new { name = x.PackageName, count = x.SubscriberCount }));
    var questionsByDayJson = JsonSerializer.Serialize(
        Model.Stats.QuestionsByDay.Select(x => new { day = x.Day.ToString("dd/MM"), count = x.QuestionCount }));
    var responseTimeDisplay = Model.Stats.AverageResponseTimeSeconds > 0
        ? $"{Model.Stats.AverageResponseTimeSeconds:0.0}s"
        : "Chưa có dữ liệu";
}

<div class="page-header">
    <div class="page-header__copy">
        <div class="page-eyebrow">Trung tâm vận hành</div>
        <h1 class="page-title">Dashboard quản trị</h1>
        <p class="page-description">Tổng quan người dùng, tài liệu, hoạt động hỏi đáp và doanh thu hệ thống.</p>
    </div>
</div>

<section class="admin-kpi-grid" aria-label="Chỉ số tổng quan">
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("users", null, null))' /></span>
            <span class="admin-kpi-card__label">Tổng người dùng</span>
        </div>
        <div class="admin-kpi-card__value">@Model.Stats.TotalUsers.ToString("N0")</div>
        <div class="admin-kpi-card__meta">+@Model.Stats.NewUsersThisMonth.ToString("N0") trong tháng này</div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("users", null, null))' /></span>
            <span class="admin-kpi-card__label">Hoạt động 7 ngày</span>
        </div>
        <div class="admin-kpi-card__value">@Model.Stats.ActiveUsers.ToString("N0")</div>
        <div class="admin-kpi-card__meta">người dùng có phiên chat gần đây</div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("document", null, null))' /></span>
            <span class="admin-kpi-card__label">Tài liệu</span>
        </div>
        <div class="admin-kpi-card__value">@Model.Stats.TotalDocuments.ToString("N0")</div>
        <div class="admin-kpi-card__meta">@Model.Stats.TotalChunks.ToString("N0") đoạn đã lập chỉ mục</div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("document", null, null))' /></span>
            <span class="admin-kpi-card__label">Chờ duyệt</span>
        </div>
        <div class="admin-kpi-card__value">@Model.Stats.PendingDocuments.ToString("N0")</div>
        <div class="admin-kpi-card__meta">+@Model.Stats.DocumentsUploadedToday.ToString("N0") tài liệu tải lên hôm nay</div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("chat", null, null))' /></span>
            <span class="admin-kpi-card__label">Câu hỏi</span>
        </div>
        <div class="admin-kpi-card__value">@Model.Stats.TotalQuestions.ToString("N0")</div>
        <div class="admin-kpi-card__meta">@Model.Stats.TotalConversations.ToString("N0") cuộc hội thoại</div>
        <div class="admin-kpi-card__insight">
            @if (Model.Stats.MostCitedReferenceCount > 0)
            {
                <span>Được trích dẫn trong nhiều câu trả lời nhất:</span>
                <strong>
                    @Model.Stats.MostCitedSubjectName
                    @if (!string.IsNullOrWhiteSpace(Model.Stats.MostCitedChapterName))
                    {
                        <text> · @Model.Stats.MostCitedChapterName</text>
                    }
                </strong>
                <span>@Model.Stats.MostCitedReferenceCount.ToString("N0") câu trả lời</span>
            }
            else
            {
                <span>Chưa có lượt trích dẫn</span>
            }
        </div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("chat", null, null))' /></span>
            <span class="admin-kpi-card__label">Phản hồi TB</span>
        </div>
        <div class="admin-kpi-card__value">@responseTimeDisplay</div>
        <div class="admin-kpi-card__meta">tính trên các hội thoại gần nhất</div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("payment", null, null))' /></span>
            <span class="admin-kpi-card__label">Doanh thu tháng</span>
        </div>
        <div class="admin-kpi-card__value">@Model.Stats.RevenueThisMonth.ToString("N0") đ</div>
        <div class="admin-kpi-card__meta">Hôm nay: @Model.Stats.RevenueToday.ToString("N0") đ</div>
    </article>
    <article class="admin-kpi-card">
        <div class="admin-kpi-card__header">
            <span class="admin-kpi-card__icon"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("payment", null, null))' /></span>
            <span class="admin-kpi-card__label">Thanh toán cần chú ý</span>
        </div>
        <div class="admin-kpi-card__value">@((Model.Stats.PendingPayments + Model.Stats.FailedPayments).ToString("N0"))</div>
        <div class="admin-kpi-card__meta">
            @Model.Stats.PendingPayments.ToString("N0") đang chờ · @Model.Stats.FailedPayments.ToString("N0") thất bại
        </div>
    </article>
</section>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title">Doanh thu 14 ngày gần nhất</h6>
                <canvas id="revenueByDayChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title">Số câu hỏi 14 ngày gần nhất</h6>
                <canvas id="questionsByDayChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title">Doanh thu theo gói</h6>
                <canvas id="revenueByPackageChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title">Phân bố gói đang hoạt động</h6>
                <canvas id="packageDistributionChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chartjs/chart.umd.js"></script>
<script>
    (function () {
        const revenueByDay = @Html.Raw(revenueByDayJson);
        const revenueByPackage = @Html.Raw(revenueByPackageJson);
        const packageDistribution = @Html.Raw(packageDistributionJson);
        const questionsByDay = @Html.Raw(questionsByDayJson);

        const gridColor = 'rgba(148, 163, 184, 0.15)';
        const textColor = '#94a3b8';

        Chart.defaults.color = textColor;

        const palette = ['#6366f1', '#22c55e', '#f59e0b', '#ef4444', '#06b6d4', '#a855f7'];

        new Chart(document.getElementById('revenueByDayChart'), {
            type: 'line',
            data: {
                labels: revenueByDay.map(x => x.day),
                datasets: [{
                    label: 'Doanh thu (đ)',
                    data: revenueByDay.map(x => x.revenue),
                    borderColor: '#22c55e',
                    backgroundColor: 'rgba(34, 197, 94, 0.15)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                scales: {
                    x: { grid: { color: gridColor } },
                    y: { grid: { color: gridColor }, beginAtZero: true }
                }
            }
        });

        new Chart(document.getElementById('questionsByDayChart'), {
            type: 'line',
            data: {
                labels: questionsByDay.map(x => x.day),
                datasets: [{
                    label: 'Số câu hỏi',
                    data: questionsByDay.map(x => x.count),
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.15)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                scales: {
                    x: { grid: { color: gridColor } },
                    y: { grid: { color: gridColor }, beginAtZero: true, ticks: { precision: 0 } }
                }
            }
        });

        new Chart(document.getElementById('revenueByPackageChart'), {
            type: 'bar',
            data: {
                labels: revenueByPackage.map(x => x.name),
                datasets: [{
                    label: 'Doanh thu (đ)',
                    data: revenueByPackage.map(x => x.revenue),
                    backgroundColor: palette
                }]
            },
            options: {
                scales: {
                    x: { grid: { color: gridColor } },
                    y: { grid: { color: gridColor }, beginAtZero: true }
                }
            }
        });

        new Chart(document.getElementById('packageDistributionChart'), {
            type: 'doughnut',
            data: {
                labels: packageDistribution.map(x => x.name),
                datasets: [{
                    data: packageDistribution.map(x => x.count),
                    backgroundColor: palette
                }]
            }
        });
    })();
</script>
}
