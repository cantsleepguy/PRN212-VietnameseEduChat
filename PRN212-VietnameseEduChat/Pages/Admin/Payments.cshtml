@page
@model PRN212_VietnameseEduChat.Pages.Admin.PaymentsModel

@{
    ViewData["Title"] = "Quản lý thanh toán";
    Layout = "_Layout";
}

<div class="page-header"><div class="page-header__copy"><div class="page-eyebrow">Quản trị thương mại</div><h1 class="page-title">Quản lý thanh toán</h1><p class="page-description">Theo dõi giao dịch VNPay và trạng thái nâng cấp dịch vụ.</p></div></div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="text-muted small">Tổng doanh thu</div>
                <div class="fs-4 text-success">@Model.TotalRevenue.ToString("N0") đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="text-muted small">Thành công</div>
                <div class="fs-4">@Model.SuccessCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="text-muted small">Đang chờ</div>
                <div class="fs-4">@Model.PendingCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="text-muted small">Thất bại/Hủy</div>
                <div class="fs-4">@Model.FailedCount</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Payments.Count == 0)
{
    <p class="text-muted">Chưa có giao dịch nào.</p>
}
else
{
    var startItem = ((Model.PageNumber - 1) * Model.ItemsPerPage) + 1;
    var endItem = Math.Min(
        Model.PageNumber * Model.ItemsPerPage,
        Model.TotalPayments);

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div class="text-muted small">
            Hiển thị @startItem-@endItem / @Model.TotalPayments giao dịch
        </div>
        <div class="text-muted small">
            Trang @Model.PageNumber / @Model.TotalPages
        </div>
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Thời gian</th>
                <th>Người dùng</th>
                <th>Gói</th>
                <th>Số tiền</th>
                <th>Mã giao dịch</th>
                <th>Nhà cung cấp</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model.Payments)
            {
                <tr>
                    <td>@payment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(payment.User?.FullName ?? payment.User?.Email ?? payment.UserId.ToString())</td>
                    <td>@payment.Package?.PackageName</td>
                    <td>@payment.Amount.ToString("N0") đ</td>
                    <td><code>@payment.TransactionId</code></td>
                    <td>@payment.Provider</td>
                    <td>
                        @if (payment.Status == "Success")
                        {
                            <span class="badge bg-success">Thành công</span>
                        }
                        else if (payment.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Đang chờ</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Thất bại</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Phân trang thanh toán">
            <ul class="pagination justify-content-end">
                <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-page="/Admin/Payments"
                       asp-route-pageNumber="@(Model.PageNumber - 1)">
                        Trước
                    </a>
                </li>

                @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
                {
                    <li class="page-item @(pageIndex == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-page="/Admin/Payments"
                           asp-route-pageNumber="@pageIndex">
                            @pageIndex
                        </a>
                    </li>
                }

                <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-page="/Admin/Payments"
                       asp-route-pageNumber="@(Model.PageNumber + 1)">
                        Sau
                    </a>
                </li>
            </ul>
        </nav>
    }
}
