@page
@model PRN212_VietnameseEduChat.Pages.Admin.PackagesModel

@{
    ViewData["Title"] = "Quản lý gói dịch vụ";
    Layout = "_Layout";
}

<h2 class="mb-3">📦 Quản lý gói dịch vụ</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="row">
    @foreach (var package in Model.Packages)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title">
                            @package.PackageName
                            <span class="text-muted small">(@package.PackageCode)</span>
                        </h5>
                        @if (package.IsActive)
                        {
                            <span class="badge bg-success">Đang bán</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ẩn</span>
                        }
                    </div>

                    <form method="post" asp-page-handler="Update">
                        <input type="hidden" name="packageId" value="@package.PackageId" />

                        <div class="mb-2">
                            <label class="form-label small">Tên gói</label>
                            <input type="text" name="packageName" class="form-control form-control-sm"
                                   value="@package.PackageName" required />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Mô tả</label>
                            <textarea name="description" class="form-control form-control-sm" rows="2">@package.Description</textarea>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-2">
                                <label class="form-label small">Giá (đ)</label>
                                <input type="number" name="price" class="form-control form-control-sm"
                                       value="@package.Price.ToString("F0")" min="0" step="1000" required />
                            </div>
                            <div class="col-6 mb-2">
                                <label class="form-label small">Thời hạn (ngày)</label>
                                <input type="number" name="durationDays" class="form-control form-control-sm"
                                       value="@package.DurationDays" min="1" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-2">
                                <label class="form-label small">Câu hỏi/ngày (trống = ∞)</label>
                                <input type="number" name="dailyQuestionLimit" class="form-control form-control-sm"
                                       value="@package.DailyQuestionLimit" min="1" />
                            </div>
                            <div class="col-6 mb-2">
                                <label class="form-label small">Upload tối đa (MB)</label>
                                <input type="number" name="maxUploadSizeMb" class="form-control form-control-sm"
                                       value="@package.MaxUploadSizeMb" min="1" required />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Số tài liệu tối đa (trống = ∞)</label>
                            <input type="number" name="maxDocuments" class="form-control form-control-sm"
                                   value="@package.MaxDocuments" min="1" />
                        </div>

                        <div class="form-check mb-2">
                            <input type="checkbox" name="isActive" value="true" class="form-check-input"
                                   id="isActive_@package.PackageId" checked="@package.IsActive" />
                            <label class="form-check-label small" for="isActive_@package.PackageId">
                                Cho phép mua/hiển thị
                            </label>
                            <input type="hidden" name="isActive" value="false" />
                        </div>

                        <button type="submit" class="btn btn-sm btn-primary w-100">💾 Lưu</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
