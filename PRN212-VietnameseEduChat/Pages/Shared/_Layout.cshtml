<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - VietnameseEduChat</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/dark-theme.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/PRN212_VietnameseEduChat.styles.css"
          asp-append-version="true" />
</head>

<body>
    @{
        var packagesPage = User.IsInRole(
            PRN212_VietnameseEduChat.Services.Security.AppRoles.SystemAdmin)
            ? "/Admin/Packages"
            : "/Packages/Index";
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom">
            <div class="container">

                <a class="navbar-brand"
                   asp-area=""
                   asp-page="/Index">
                    VietnameseEduChat
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Bật/tắt thanh điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-area=""
                                   asp-page="/Dashboard">
                                    🏠 Trang chủ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Documents/Index">
                                    📄 Tài liệu
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Chat/Index">
                                    💬 Chat tài liệu
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="@packagesPage">
                                    💎 Gói dịch vụ
                                </a>
                            </li>

                            @if (User.IsInRole(
                                                    PRN212_VietnameseEduChat.Services.Security.AppRoles.AcademicAdmin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-page="/Subjects/Index">
                                        📚 Môn học
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-page="/ResearchQuestions/Index">
                                        🔬 Test set RBL
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-page="/ResearchExperiments/Index">
                                        📊 RBL Benchmark
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole(
                                                    PRN212_VietnameseEduChat.Services.Security.AppRoles.AcademicAdmin) ||
                                                    User.IsInRole(
                                                    PRN212_VietnameseEduChat.Services.Security.AppRoles.SystemAdmin))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle"
                                       href="#"
                                       role="button"
                                       data-bs-toggle="dropdown"
                                       aria-expanded="false">
                                        🛠️ Quản trị
                                    </a>

                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item"
                                               asp-page="/Admin/Dashboard">
                                                📈 Dashboard
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item"
                                               asp-page="/Admin/ChunkingConfig">
                                                ⚙️ Cấu hình Chunking
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item"
                                               asp-page="/Admin/Packages">
                                                📦 Gói dịch vụ
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item"
                                               asp-page="/Admin/Payments">
                                                💳 Thanh toán
                                            </a>
                                        </li>

                                        @if (User.IsInRole(
                                                                        PRN212_VietnameseEduChat.Services.Security.AppRoles.SystemAdmin))
                                        {
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-page="/Admin/Users/Index">
                                                    👥 Quản lý tài khoản
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </li>
                            }
                        }

                    </ul>

                    <ul class="navbar-nav">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link"
                                      style="color: var(--text-secondary) !important;">
                                    👤 @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger"
                                   asp-page="/Logout">
                                    Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary"
                                   asp-page="/Login">
                                    Đăng nhập
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container py-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top">
        <div class="container">
            &copy; 2026 - VietnameseEduChat -

            <a asp-area=""
               asp-page="/Privacy">
                Chính sách riêng tư
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>