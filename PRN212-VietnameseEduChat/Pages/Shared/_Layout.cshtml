<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PRN212_VietnameseEduChat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PRN212_VietnameseEduChat.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">

                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    VietnameseEduChat
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Bật/tắt thanh điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area=""
                               asp-page="/Index">
                                Trang chủ
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-page="/Documents/Index">
                                    Tài liệu
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-page="/Chat/Index">
                                    Chat tài liệu
                                </a>
                            </li>

                            @if (User.IsInRole(PRN212_VietnameseEduChat.Services.Security.AppRoles.AcademicAdmin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-page="/Subjects/Index">
                                        Môn học
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-page="/ResearchQuestions/Index">
                                        Test set RBL
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-page="/ResearchExperiments/Index">
                                        RBL Benchmark
                                    </a>
                                </li>
                            }
                        }

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area=""
                               asp-page="/Privacy">
                                Chính sách riêng tư
                            </a>
                        </li>

                    </ul>

                    <ul class="navbar-nav">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-primary">
                                    Xin chào @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger"
                                   asp-page="/Logout">
                                    Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary"
                                   asp-page="/Login">
                                    Đăng nhập
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - VietnameseEduChat -
            <a asp-area="" asp-page="/Privacy">
                Chính sách riêng tư
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>