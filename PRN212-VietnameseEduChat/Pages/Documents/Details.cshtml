@page
@model PRN212_VietnameseEduChat.Pages.Documents.DetailsModel

@{
    ViewData["Title"] = "Chi tiết tài liệu";
    var document = Model.Document;
}

<div class="page-header">
    <div class="page-header__copy">
        <div class="page-eyebrow">Thư viện học tập</div>
        <h1 class="page-title">Chi tiết tài liệu</h1>
        <p class="page-description">Thông tin tệp, trạng thái xử lý và nội dung đã được lập chỉ mục.</p>
    </div>
    <div class="page-actions">
        <a asp-page="Index" class="btn btn-secondary">Quay lại</a>
        @if (document != null)
        {
            <a asp-page="Index"
               asp-page-handler="Download"
               asp-route-id="@document.DocumentId"
               class="btn btn-primary"><partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("document", null, "app-icon--sm"))' /> Tải xuống</a>
        }
    </div>
</div>

@if (document == null)
{
    <div class="alert alert-danger">Không tìm thấy tài liệu.</div>
    return;
}

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">Thông tin tài liệu</div>
            <div class="card-body">
                <table class="table table-sm mb-0" style="border:none;">
                    <tbody>
                        <tr>
                            <td style="width:140px; color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Tiêu đề</td>
                            <td style="font-weight:600; border:none; padding:0.5rem 0;">@document.Title</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">File gốc</td>
                            <td style="border:none; padding:0.5rem 0;">@document.OriginalFileName</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Môn học</td>
                            <td style="border:none; padding:0.5rem 0;">@(document.Subject?.SubjectName ?? "Chưa phân loại")</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Chương</td>
                            <td style="border:none; padding:0.5rem 0;">@(document.Chapter?.ChapterName ?? "Chưa phân loại")</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Loại file</td>
                            <td style="border:none; padding:0.5rem 0;">@document.ContentType</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Dung lượng</td>
                            <td style="border:none; padding:0.5rem 0;">@FormatFileSize(document.FileSize)</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Người upload</td>
                            <td style="border:none; padding:0.5rem 0;">@(document.User?.FullName ?? document.User?.Email ?? "Không rõ")</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Ngày upload</td>
                            <td style="border:none; padding:0.5rem 0;">@document.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Trạng thái</td>
                            <td style="border:none; padding:0.5rem 0;">
                                @if (document.Status == "Approved") { <span class="badge bg-success">Đã duyệt</span> }
                                else if (document.Status == "Processing") { <span class="badge bg-warning text-dark">Đang xử lý</span> }
                                else if (document.Status == "PendingApproval") { <span class="badge bg-secondary">Chờ duyệt</span> }
                                else if (document.Status == "Rejected") { <span class="badge bg-danger">Đã từ chối</span> }
                                else if (document.Status == "Failed") { <span class="badge bg-danger">Thất bại</span> }
                                else { <span class="badge bg-secondary">@document.Status</span> }
                            </td>
                        </tr>
                        <tr>
                            <td style="color:var(--text-muted); font-size:0.85rem; border:none; padding:0.5rem 0;">Tổng chunks</td>
                            <td style="border:none; padding:0.5rem 0;">@document.TotalChunks</td>
                        </tr>
                    </tbody>
                </table>

                @if (!string.IsNullOrWhiteSpace(document.ErrorMessage))
                {
                    <div class="alert alert-danger mt-2">
                        <strong>Lỗi xử lý:</strong> @document.ErrorMessage
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">Kết quả xử lý AI</div>
            <div class="card-body">
                @if (document.Status == "PendingApproval")
                {
                    <div class="alert alert-info mb-0">
                        Tài liệu đã được trích xuất, chia thành <strong>@document.TotalChunks</strong> đoạn và tạo embedding thành công. Đang chờ duyệt.
                    </div>
                }
                else if (document.Status == "Approved")
                {
                    <div class="alert alert-success mb-0">Tài liệu đã được duyệt và hiển thị cho sinh viên.</div>
                }
                else if (document.Status == "Rejected")
                {
                    <div class="alert alert-warning mb-0">
                        Tài liệu đã bị từ chối.
                        @if (!string.IsNullOrWhiteSpace(document.RejectionReason))
                        {
                            <div class="mt-2"><strong>Lý do:</strong> @document.RejectionReason</div>
                        }
                    </div>
                }
                else if (document.Status == "Failed")
                {
                    <div class="alert alert-danger mb-0">Tài liệu đã tải lên nhưng xử lý nội dung thất bại.</div>
                }
            </div>
        </div>
    </div>

    @if (document.ContentType == "application/pdf")
    {
        <div class="col-md-7">
            <div class="card">
                <div class="card-header">Xem file PDF</div>
                <div class="card-body" style="padding:0; border-radius:0 0 10px 10px; overflow:hidden;">
                    <iframe src="@Url.Page("Details", "Preview", new { id = document.DocumentId })"
                            style="width: 100%; height: 620px; border: none;"></iframe>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.CanViewChunks)
{
    var chunks = document.Chunks
        .OrderBy(x => x.ChunkIndex)
        .ToList();

    <section class="mt-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="mb-0">Các đoạn chunk</h4>
            <span class="badge bg-secondary">@chunks.Count đoạn</span>
        </div>

        @if (chunks.Count == 0)
        {
            <div class="alert alert-info">
                Tài liệu này chưa có dữ liệu chunk để hiển thị.
            </div>
        }
        else
        {
            <div class="accordion" id="documentChunksAccordion">
                @foreach (var chunk in chunks)
                {
                    var headingId = $"chunk-heading-{chunk.DocumentChunkId}";
                    var collapseId = $"chunk-collapse-{chunk.DocumentChunkId}";
                    var isFirst = chunk.ChunkIndex == chunks[0].ChunkIndex;

                    <div class="accordion-item">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button @(isFirst ? "" : "collapsed")"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="@(isFirst ? "true" : "false")"
                                    aria-controls="@collapseId">
                                <span class="fw-semibold">Chunk #@chunk.ChunkIndex</span>
                                <span class="ms-2 text-muted small">
                                    @FormatChunkLocation(document, chunk)
                                    · @FormatCharacterCount(chunk.Content)
                                    · @chunk.EmbeddingModel (@chunk.EmbeddingDimensions chiều)
                                </span>
                            </button>
                        </h2>
                        <div id="@collapseId"
                             class="accordion-collapse collapse @(isFirst ? "show" : "")"
                             aria-labelledby="@headingId"
                             data-bs-parent="#documentChunksAccordion">
                            <div class="accordion-body">
                                <pre class="mb-0"
                                     style="white-space:pre-wrap; word-break:break-word; font-size:0.9rem; line-height:1.55;">@chunk.Content</pre>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
}

@functions {
    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return bytes + " bytes";
        var kb = bytes / 1024.0;
        if (kb < 1024) return kb.ToString("0.00") + " KB";
        return (kb / 1024.0).ToString("0.00") + " MB";
    }

    private string FormatCharacterCount(string content)
    {
        var count = string.IsNullOrEmpty(content)
            ? 0
            : content.Length;

        return count.ToString("N0") + " ký tự";
    }

    private string FormatChunkLocation(
        PRN212_VietnameseEduChat.BusinessObjects.Entities.Document document,
        PRN212_VietnameseEduChat.BusinessObjects.Entities.DocumentChunk chunk)
    {
        if (chunk.PageNumber.HasValue)
        {
            return document.ContentType == "application/vnd.openxmlformats-officedocument.presentationml.presentation"
                ? $"Slide {chunk.PageNumber.Value}"
                : $"Trang {chunk.PageNumber.Value}";
        }

        return document.ContentType switch
        {
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document" =>
                "DOCX không có số trang cố định",

            "application/vnd.openxmlformats-officedocument.presentationml.presentation" =>
                "Không xác định slide",

            _ => "Không xác định trang"
        };
    }
}
