@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="login-page">
    <section class="login-story" aria-label="Giới thiệu VietnameseEduChat">
        <div class="login-story__content">
            <div class="page-eyebrow login-story__eyebrow">Không gian học tập thông minh</div>
            <h1>Hiểu tài liệu nhanh hơn cùng AI.</h1>
            <p>Đặt câu hỏi trực tiếp trên giáo trình, bài giảng và tài liệu đã được giảng viên xác thực. Mỗi câu trả lời đều đi kèm nguồn tham khảo rõ ràng.</p>
        </div>
    </section>

    <section class="login-panel">
        <div class="login-box">
            <div class="login-logo">
                <div class="login-logo-icon">
                    <partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("book", null, "app-icon--lg"))' />
                </div>
                <div class="login-title">Chào mừng bạn trở lại</div>
                <div class="login-subtitle">Đăng nhập để tiếp tục không gian học tập của bạn.</div>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger mb-3" role="alert">@TempData["ErrorMessage"]</div>
            }

            <div asp-validation-summary="All" class="mb-3" role="alert"></div>

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="tenban@example.com" autocomplete="username" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <div class="password-field">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" autocomplete="current-password" />
                        <button type="button" class="password-toggle" data-password-toggle aria-controls="Password" aria-pressed="false" aria-label="Hiện mật khẩu">
                            <partial name="_Icon" model='@(ValueTuple.Create<string, string?, string?>("eye", null, "app-icon--sm"))' />
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn btn-primary login-submit">Đăng nhập</button>
            </form>

            <div class="demo-credentials">
                Tài khoản trải nghiệm: <strong>student@gmail.com</strong> · Mật khẩu: <strong>123456</strong>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
