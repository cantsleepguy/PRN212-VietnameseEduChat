@page
@model PRN212_VietnameseEduChat.Pages.Packages.IndexModel

@{
    ViewData["Title"] = "Gói dịch vụ";
    Layout = "_Layout";
}

<div class="page-header">
    <div class="page-header__copy">
        <div class="page-eyebrow">Nâng cấp trải nghiệm</div>
        <h1 class="page-title">Gói dịch vụ</h1>
        <p class="page-description">Chọn hạn mức phù hợp với nhu cầu học tập và quản lý tài liệu của bạn.</p>
    </div>
    <a asp-page="History" class="btn btn-secondary">Lịch sử thanh toán</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (Model.CurrentPackageInfo != null)
{
    var info = Model.CurrentPackageInfo;

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Gói hiện tại của bạn: <span class="text-primary">@info.Package.PackageName</span></h5>

            <div class="row mt-3">
                <div class="col-md-4">
                    <div class="text-muted small">Câu hỏi hôm nay</div>
                    <div class="fs-5">
                        @info.QuestionsUsedToday /
                        @(info.Package.DailyQuestionLimit.HasValue
                            ? info.Package.DailyQuestionLimit.Value.ToString()
                            : "Không giới hạn")
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Tài liệu đã tải lên</div>
                    <div class="fs-5">
                        @info.DocumentsOwned /
                        @(info.Package.MaxDocuments.HasValue
                            ? info.Package.MaxDocuments.Value.ToString()
                            : "Không giới hạn")
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Dung lượng tối đa mỗi file</div>
                    <div class="fs-5">@info.Package.MaxUploadSizeMb MB</div>
                </div>
            </div>

            @if (info.Subscription != null)
            {
                <div class="mt-3 text-muted small">
                    Hiệu lực đến: @info.Subscription.EndDate.ToString("dd/MM/yyyy HH:mm")
                </div>
            }
        </div>
    </div>
}

<div class="row">
    @foreach (var package in Model.Packages)
    {
        var isCurrent = Model.CurrentPackageInfo?.Package.PackageId == package.PackageId;

        <div class="col-md-4 mb-3">
            <div class="card h-100 @(isCurrent ? "border-primary" : "")">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@package.PackageName</h5>

                    <div class="fs-4 mb-2">
                        @if (package.Price == 0)
                        {
                            <span>Miễn phí</span>
                        }
                        else
                        {
                            <span>@package.Price.ToString("N0") đ</span>
                            <span class="text-muted fs-6">/ @(package.DurationDays > 0 ? $"{package.DurationDays} ngày" : "vô hạn")</span>
                        }
                    </div>

                    <p class="text-muted small">@package.Description</p>

                    <ul class="list-unstyled small flex-grow-1">
                        <li><span class="feature-check" aria-hidden="true">✓</span> @(package.DailyQuestionLimit.HasValue
                            ? $"{package.DailyQuestionLimit} câu hỏi/ngày"
                            : "Không giới hạn câu hỏi")</li>
                        <li><span class="feature-check" aria-hidden="true">✓</span> Tối đa @package.MaxUploadSizeMb MB mỗi file</li>
                        <li><span class="feature-check" aria-hidden="true">✓</span> @(package.MaxDocuments.HasValue
                            ? $"Tối đa {package.MaxDocuments} tài liệu"
                            : "Không giới hạn tài liệu")</li>
                        @if (package.AllowAiFeatures)
                        {
                            <li><span class="feature-check" aria-hidden="true">✓</span> Đầy đủ tính năng AI</li>
                        }
                    </ul>

                    @if (isCurrent)
                    {
                        <button class="btn btn-outline-primary" disabled>Gói hiện tại</button>
                    }
                    else if (package.Price > 0)
                    {
                        <form method="post" asp-page-handler="Buy">
                            <input type="hidden" name="packageId" value="@package.PackageId" />
                            <button type="submit" class="btn btn-primary w-100">Mua gói này</button>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary" disabled>Gói mặc định</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-page="/Packages/History">Xem lịch sử thanh toán</a>
</div>
