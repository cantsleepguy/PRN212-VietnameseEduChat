@page
@model PRN212_VietnameseEduChat.Pages.Subjects.IndexModel

@{
    ViewData["Title"] = "Quản lý môn học";
}

<h2>Quản lý môn học / chương</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        Tạo môn học mới
    </div>

    <div class="card-body">
        <form method="post"
              asp-page-handler="CreateSubject">

            <div class="mb-3">
                <label class="form-label">
                    Tên môn học
                </label>

                <input asp-for="NewSubjectName"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Mô tả
                </label>

                <textarea asp-for="NewSubjectDescription"
                          class="form-control">
                </textarea>
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Tạo môn học
            </button>

        </form>
    </div>
</div>

@if (Model.Subjects.Count == 0)
{
    <div class="alert alert-info">
        Chưa có môn học nào.
    </div>
}
else
{
    foreach (var subject in Model.Subjects)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>@subject.SubjectName</strong>

                    @if (!string.IsNullOrWhiteSpace(subject.Description))
                    {
                        <div class="text-muted small">
                            @subject.Description
                        </div>
                    }
                </div>

                <form method="post"
                      asp-page-handler="DeleteSubject"
                      asp-route-id="@subject.SubjectId"
                      onsubmit="return confirm('Bạn có chắc muốn xóa môn học này không?');">

                    <button type="submit"
                            class="btn btn-sm btn-danger">
                        Xóa môn
                    </button>

                </form>
            </div>

            <div class="card-body">
                <h5>Danh sách chương</h5>

                @if (subject.Chapters.Count == 0)
                {
                    <div class="alert alert-warning">
                        Môn học này chưa có chương.
                    </div>
                }
                else
                {
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th style="width: 100px;">Thứ tự</th>
                                <th>Tên chương</th>
                                <th style="width: 120px;">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var chapter in subject.Chapters)
                            {
                                <tr>
                                    <td>@chapter.OrderIndex</td>

                                    <td>@chapter.ChapterName</td>

                                    <td>
                                        <form method="post"
                                              asp-page-handler="DeleteChapter"
                                              asp-route-id="@chapter.ChapterId"
                                              onsubmit="return confirm('Bạn có chắc muốn xóa chương này không?');">

                                            <button type="submit"
                                                    class="btn btn-sm btn-danger">
                                                Xóa
                                            </button>

                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <hr />

                <h5>Thêm chương mới</h5>

                <form method="post"
                      asp-page-handler="CreateChapter"
                      class="row g-2">

                    <input type="hidden"
                           name="ChapterSubjectId"
                           value="@subject.SubjectId" />

                    <div class="col-md-2">
                        <input type="number"
                               name="NewChapterOrderIndex"
                               class="form-control"
                               value="1"
                               min="1"
                               placeholder="Thứ tự" />
                    </div>

                    <div class="col-md-8">
                        <input type="text"
                               name="NewChapterName"
                               class="form-control"
                               placeholder="Tên chương" />
                    </div>

                    <div class="col-md-2">
                        <button type="submit"
                                class="btn btn-success w-100">
                            Thêm
                        </button>
                    </div>

                </form>
            </div>
        </div>
    }
}
